   "source": [
    "def largest_number(a,b,c):\n",
    "    if a>b and a>c:\n",
    "        return a \n",
    "    elif b>a and b>c:\n",
    "        return b \n",
    "    else:\n",
    "        return c\n",
    "print(\"the largest number among three is\",largest_number(10,14,18))"
   ]
