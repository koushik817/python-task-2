    "def reverse_string(a):\n",
    "    if a==\"\":\n",
    "        return a\n",
    "    else :\n",
    "        return reverse_string(a[1:])+a[0]\n",
    "string = input(\"enter the string:\")\n",
    "print(reverse_string(string))\n"
   ]
